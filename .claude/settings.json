{
  "permissions": {
    "allow": [
      "Bash(bun *)",
      "Bash(bunx *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(cargo *)",
      "Bash(ig *)",
      "Bash(mkdir *)",
      "Bash(ls *)",
      "Bash(mv *)",
      "Bash(rm *)",
      "Bash(cp *)"
    ]
  },
  "hooks": {
    "WorktreeCreate": [
      {
        "type": "command",
        "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/create-worktree.sh"
      }
    ],
    "WorktreeRemove": [
      {
        "type": "command",
        "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/remove-worktree.sh"
      }
    ]
  }
}
