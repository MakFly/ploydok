{
	admin 0.0.0.0:2019
}

# Route control-plane : sert le frontend web sur localhost (et le hostname
# public quand il pointe sur ce serveur). Les routes app utilisateur sont
# insérées avant ce fallback via l'Admin API Caddy.
(control_plane) {
	handle_path /api/* {
		reverse_proxy api:3335 {
			header_up X-Forwarded-Prefix /api
		}
	}
	handle /auth/* {
		reverse_proxy api:3335
	}
	handle /github/* {
		reverse_proxy api:3335
	}
	handle /gitlab/* {
		reverse_proxy api:3335
	}
	handle /stripe {
		reverse_proxy api:3335
	}
	handle {
		reverse_proxy web:3000
	}
}

${PLOYDOK_CONTROL_PLANE_SITE}

:80 {
	@control_plane host ${PLOYDOK_CONTROL_PLANE_HOSTS}
	route @control_plane {
		import control_plane
	}
}
