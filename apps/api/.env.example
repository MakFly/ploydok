# Copie vers .env.local et garde stable entre les reloads de bun --watch.
# Ne JAMAIS commiter .env.local.

# === Secrets obligatoires ===
# 32 chars min. Signe les access JWT — change-le → tous les users déconnectés.
SESSION_SECRET=dev_session_secret_please_change_0123456789abcdef0123456789abcdef
# Utilisé pour chiffrer les secrets applicatifs (Sprint 4). base64 32 bytes.
MASTER_KEY=dev_master_key_please_change_abcdefghijklmnopqrstuvwxyz0123=

# === Optionnel (défauts OK en dev) ===
# PORT=4000
# WEB_ORIGIN=http://localhost:5173
# DATABASE_URL=../../ploydok.db

# === SMTP (Mailpit en dev) ===
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_FROM=Ploydok <noreply@ploydok.local>

# === Infra (optionnel, /debug/spawn-nginx uniquement) ===
# PLOYDOK_BOOT_INFRA=1
# PLOYDOK_AGENT_SOCKET=/tmp/ploydok-agent.sock
# CADDY_ADMIN_URL=http://127.0.0.1:2020
