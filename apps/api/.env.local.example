# Ploydok API — environment variables template
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — NEVER commit it.
#
# Run `make secrets-init` to auto-generate passwords and URLs.

# ------------------------------------------------------------------
# Database (Postgres 16)
# ------------------------------------------------------------------
DATABASE_URL=postgres://ploydok:<PLOYDOK_PG_PASSWORD>@127.0.0.1:5434/ploydok
PLOYDOK_PG_PASSWORD=

# ------------------------------------------------------------------
# Redis 7
# ------------------------------------------------------------------
REDIS_URL=redis://:<PLOYDOK_REDIS_PASSWORD>@127.0.0.1:6381/0
PLOYDOK_REDIS_PASSWORD=

# ------------------------------------------------------------------
# Auth secrets (auto-generated if absent in dev, required in prod)
# ------------------------------------------------------------------
SESSION_SECRET=
MASTER_KEY=

# ------------------------------------------------------------------
# Optional overrides
# ------------------------------------------------------------------
# NODE_ENV=dev
# PORT=3335
# WEB_ORIGIN=http://localhost:5173
# PLOYDOK_REGISTRY_URL=127.0.0.1:5000
# PLOYDOK_REGISTRY_PUSH_URL=registry:5000
# PLOYDOK_BUILDKIT_ADDR=docker-container://ploydok-buildkitd
